# 服务端环境变量示例（复制为 .env 使用，.env 含密钥不入库）
PORT=3000
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d
DATABASE_URL="file:./dev.db"

# 运行环境：生产设为 production（日志输出 JSON，便于日志采集）；
# 留空或 development 则本地用 pino-pretty 彩色输出。
NODE_ENV=production

# 日志级别：trace < debug < info < warn < error < fatal，默认 info。
# 排查「部分用户报错」时临时设为 debug，可看到每个请求的 userId / 路径 / 耗时。
LOG_LEVEL=info
